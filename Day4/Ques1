Find the duplicate no
https://leetcode.com/problems/find-the-duplicate-number/description/


// Optimal- O(n), O(1)
class Solution {
public:
    int findDuplicate(vector<int>& nums) {
        int slow=nums[0],fast=nums[0];
        do{
            slow=nums[slow];
            fast=nums[nums[fast]];
        }while(slow!=fast);
        slow = nums[0];
        while (slow != fast) {
            slow = nums[slow];
            fast = nums[fast]; 
        }
        return slow;
    }
};

// optimal

class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& arr) {
        int n=arr.size(),c=0,ans=0;
        for(int i=0;i<n;i++){
            if(arr[i]==1){
                c++;
                ans=max(ans,c);
            }
            else c=0;
        }
        return ans;
    }
};

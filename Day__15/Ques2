class Solution{
    public:
    int findPlatform(vector<int>& arr, vector<int>& dep){
        sort(arr.begin(),arr.end());
        sort(dep.begin(),dep.end());
        int i = 0, j = 0;
        int plat = 0, ans = 0;
        while (i < n && j < n) {
            if (arr[i] <= dep[j]) {
                plat++;
                ans = max(ans, plat);
                i++;
            } else {
                plat--;
                j++;
            }
        }
        return ans;
    }
};

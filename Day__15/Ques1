class Solution{
    public:
    int maxMeetings(vector<int>& start, vector<int>& end){
        int n=start.size();
        vector<vector<int>>arr;
        for(int i=0;i<n;i++){
            arr.push_back({end[i],start[i]});
        }
        sort(arr.begin(),arr.end());
        int l=-1,c=0;
        for(int i=0;i<n;i++){
            if(arr[i][1]>l){
                c++;
                l=arr[i][0];
            }
        }
        return c;
    }
};

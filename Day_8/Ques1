// Optimal- O(n), SC- O(n)

int maxLen(vector<int>& arr, int n) {
    unordered_map<long long,int> mp;
    long long sum = 0;
    int ans = 0;
    mp[0]=-1; 
    for(int i = 0; i < n; i++) {
        sum += arr[i];
        if(mp.find(sum) != mp.end()) {
            ans = max(ans, i - mp[sum]);
        }
        else {
            mp[sum] = i;  
        }
    }
    return ans;
}
